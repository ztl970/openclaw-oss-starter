# Public-safe sample config for a local multi-instance setup.
# Copy this file to a private location before editing real values.

# Local workspace roots
OPENCLAW_WORKSPACE_MAIN=/Users/ztl/01-main
OPENCLAW_WORKSPACE_FAMILY=/Users/ztl/02-family
OPENCLAW_WORKSPACE_MEDIA=/Users/ztl/03-media
OPENCLAW_WORKSPACE_BUSINESS=/Users/ztl/04-business
OPENCLAW_WORKSPACE_ZTL970=/Users/ztl/05-ztl970

# Quota-aware switching
OPENCLAW_CODEX_THRESHOLD=20
OPENCLAW_QUOTA_SWITCH_TARGET=minimax-portal/MiniMax-M2.5-highspeed

# Release packaging
OPENCLAW_PUBLIC_PACK_NAME=openclaw-oss-starter-public-pack
OPENCLAW_PUBLIC_PACK_OUTPUT=dist
